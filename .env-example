# --- TourAPI (공공데이터포털) ---
# 데이터셋: 15101578 "한국관광공사_국문 관광정보 서비스_GW" (= KorService2)
#   https://www.data.go.kr/data/15101578/openapi.do  ← 여기서 '활용신청' 후 서비스키 발급
# 서비스키는 Decoding 키 사용 권장(코드에서 그대로 쿼리에 붙음).
TOURAPI_SERVICE_KEY=
TOURAPI_BASE_URL=https://apis.data.go.kr/B551011/KorService2
# 배치 적재(전체). 변경분 동기화로 가면 areaBasedSyncList2 로 교체.
TOURAPI_AREA_BASED_OP=areaBasedList2
TOURAPI_MOBILE_APP=stanat
TOURAPI_TIMEOUT_SECONDS=10

# --- 배치 기본값 ---
BATCH_NUM_OF_ROWS=100
# BATCH_MAX_PAGES=          # 비우면 끝까지
BATCH_ARRANGE=C

# --- DB (스키마는 backend-spring Flyway 소유; 여기선 따르기만) ---
# TiDB(MySQL 호환). 예: mysql+pymysql://user:pass@host:4000/stanat?charset=utf8mb4
DATABASE_URL=
DB_ECHO=false
